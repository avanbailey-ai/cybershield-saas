# Your deployed URL — required for Stripe (e.g. https://cybershield.vercel.app)
# Do NOT use localhost — Stripe requires a publicly accessible URL
# Also used for auth email redirect links
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Supabase Project URL — found in: Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon (public) key — found in: Project Settings > API > Project API Keys > anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role key — found in: Project Settings > API > Project API Keys > service_role
# WARNING: Never expose this in client-side code or commit it to version control
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Secret token for the Vercel Cron endpoint — set to a long random string
CRON_SECRET=your-secret-here

# Resend API key for transactional email — get yours at https://resend.com
# When set, uncomment the Resend block in lib/email.ts and remove the mock
RESEND_API_KEY=re_your_key_here

# ── Stripe ──────────────────────────────────────────────────────────────────
# Secret key — found in: Stripe Dashboard > Developers > API keys
# WARNING: Never expose this in client-side code or commit it to version control
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — found in: Stripe Dashboard > Webhooks > your endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# Publishable key — safe for frontend use
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs — set these after creating products in the Stripe Dashboard
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_AGENCY=price_...
