# Copy to .env.local and fill in values from your Supabase project settings.
# NEVER commit .env.local — it is gitignored.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — never expose to the browser or commit real values
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Production canonical URL (also set in Vercel env for cybershield-saas-1o19)
# NEXT_PUBLIC_SITE_URL=https://cybershieldcloud.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Platform owner (Founder OS, admin routes). Defaults to avanbailey@gmail.com if unset.
# OWNER_EMAIL=avanbailey@gmail.com

# Stripe (use test keys locally; required for checkout)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_AGENCY=price_...

# Cron / internal workers — use a long random string
CRON_SECRET=your-cron-secret

# Optional — email alerts and digests (Resend)
RESEND_API_KEY=re_...
# Verify mail.cybershieldcloud.com in Resend — segmented senders (production)
# EMAIL_FROM=CyberShield <alerts@mail.cybershieldcloud.com>
# Per-category overrides (optional):
# EMAIL_FROM_OUTREACH=CyberShield <outreach@mail.cybershieldcloud.com>
# EMAIL_FROM_ONBOARDING=CyberShield <success@mail.cybershieldcloud.com>
# EMAIL_REPLY_TO=support@mail.cybershieldcloud.com
EMAIL_SENDING_DOMAIN=mail.cybershieldcloud.com
EMAIL_LINKS_DOMAIN=links.cybershieldcloud.com
EMAIL_TRACK_DOMAIN=track.cybershieldcloud.com
# Set true after CNAME links + track to your app host
# EMAIL_USE_CUSTOM_TRACKING=true
# EMAIL_TRACKING_SECRET=long-random-string
# Resend webhook → https://cybershieldcloud.com/api/resend/webhook
# RESEND_WEBHOOK_SECRET=long-random-string
# Optional — recipient for scripts/test-resend-customer-delivery.ts
# RESEND_TEST_TO=you@example.com

# Optional — enterprise AI narratives
OPENAI_API_KEY=sk-...

# Optional — enterprise lead routing
ADMIN_EMAIL=you@example.com
