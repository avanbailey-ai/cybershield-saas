# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# On Vercel, set these in Project Settings > Environment Variables,
# or pull them locally with: vercel env pull .env.local
#
# scripts/set-vercel-env.mjs reads NEXT_PUBLIC_* values from your shell env.

# ── Public app URL (required for Stripe, auth redirects, email links) ────────
# Use your Vercel deployment URL — not localhost for Stripe webhooks/checkout
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
# Optional alias used in some routes
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Supabase (Project Settings > API) ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Server-only — never expose in client code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Vercel Cron / worker auth ────────────────────────────────────────────────
# Long random string — Vercel Cron sends Authorization: Bearer CRON_SECRET automatically
CRON_SECRET=your-secret-here

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_key_here

# ── Stripe (Dashboard > Developers) ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Price IDs from Stripe Dashboard (must be price_ IDs, not prod_)
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_AGENCY=price_...

# ── Optional: AI security reports ────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Optional: scan worker tuning (defaults used when unset) ──────────────────
# SCAN_BATCH_LIMIT=10
# SCAN_WORKER_CONCURRENCY=3
# SCAN_JOB_TIMEOUT_MS=120000

# ── Optional: local dev tooling ──────────────────────────────────────────────
# GIT_PATH=C:\Path\To\git.exe

# Validation helper: lib/env/validate.ts
