# Copy to .env.local and fill in values from your Supabase project settings.
# NEVER commit .env.local — it is gitignored.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — never expose to the browser or commit real values
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Production canonical URL (also set in Vercel env for cybershield-saas-1o19)
# NEXT_PUBLIC_SITE_URL=https://cybershieldcloud.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (use test keys locally; required for checkout)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_AGENCY=price_...

# Cron / internal workers — use a long random string
CRON_SECRET=your-cron-secret

# Optional — email alerts and digests
RESEND_API_KEY=re_...

# Optional — enterprise AI narratives
OPENAI_API_KEY=sk-...

# Optional — enterprise lead routing
ADMIN_EMAIL=you@example.com
